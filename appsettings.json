{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=db,1433;Database=EcommerceDb;User=sa;Password=YourStrong!Pass123;TrustServerCertificate=True;"
  },
  "AdminAuth": {
    "Username": "__SET_FROM_ENV_ADMINAUTH__USERNAME__",
    "Password": "__SET_FROM_ENV_ADMINAUTH__PASSWORD__"
  },
  "Jwt": {
    "Key": "__SET_FROM_ENV_JWT__KEY__",
    "Issuer": "EcommerceAPI",
    "Audience": "EcommerceClient",
    "ExpiryInMinutes": 60
  },
  "Encryption": {
    "Key": "__SET_FROM_ENV_ENCRYPTION__KEY__"
  }
}
